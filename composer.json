{
    "name": "jotaelesalinas/php-data-streams",
    "type": "library",
    "description": "Read and write huge CSV, JSON, XML and Excel streams in PHP without running out of memory.",
    "keywords": [
        "csv",
        "tsv",
        "json",
        "ndjson",
        "xml",
        "excel",
        "xlsx",
        "generators",
        "streaming",
        "large-files",
        "memory-efficient",
        "data-streams"
    ],
    "homepage": "https://github.com/jotaelesalinas/php-data-streams",
    "license": "MIT",
    "authors": [
        {
            "name": "José Luis Salinas",
            "email": "jotaelesalinas@example.com",
            "homepage": "https://github.com/jotaelesalinas",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "JLSalinas\\DataStreams\\": "packages/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JLSalinas\\DataStreams\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --no-progress",
        "format": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff"
    },
    "config": {
        "sort-packages": true
    }
}
